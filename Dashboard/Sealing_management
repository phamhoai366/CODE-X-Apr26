    <script>
        let yieldChart = null;

        const lineConfig = {
            8: { products: ['SA', 'SB', 'SC', 'SD'] },
            9: { products: ['SA', 'SB', 'SC', 'SD'] },
            10: { products: ['SA', 'SB', 'SC', 'SD'] },
            11: { products: ['SA', 'SB', 'SC', 'SD'] },
            12: { products: ['SA', 'SB', 'SC', 'SD'] },
            13: { products: ['SA', 'SB', 'SC', 'SD'] },
            14: { products: ['SA', 'SB', 'SC', 'SD'] }
        };

        async function loadData() {
            try {
                const apiUrl = '<?php echo $api_endpoint; ?>';
                const response = await fetch(apiUrl);
                
                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }

                const result = await response.json();

                if (result.success) {
                    renderTables(result.data);
                    renderChart(result.performance);
                    updateInfoBox(result.performance);
                    updateTimestamp(result.timestamp);
                    clearError();
                } else {
                    showError('Error: Unable to load data from API');
                }
            } catch (error) {
                console.error('Error loading data:', error);
                showError('❌ Connection Error: ' + error.message);
            }
        }

        function renderTables(data) {
            const container = document.getElementById('tablesContainer');
            const lines = [8, 9, 10, 11, 12, 13, 14];
            const products = ['SA', 'SB', 'SC', 'SD'];

            let html = '<div class="line-grid">';

            lines.forEach(line => {
                const lineData = data.filter(d => d.row_id === line);

                html += `
                    <section class="line-card">
                        <div class="line-header">Line ${line}</div>
                        <div class="product-grid">
                `;

                products.forEach(product => {
                    const record = lineData.find(d => d.product_id === product);
                    const total = record ? (record.san_luong || '-') : '-';
                    const created = record ? (record.ngay_tao || '-') : '-';
                    const lifetime = record ? (record.chu_ki || '-') : '-';
                    const plan = record ? (record.ke_hoach || '-') : '-';

                    html += `
                        <article class="product-card">
                            <div class="product-title">${product}</div>
                            <div class="metric-row"><span class="metric-label">Total</span><span class="metric-value">${total}</span></div>
                            <div class="metric-row"><span class="metric-label">Created</span><span class="metric-value">${created}</span></div>
                            <div class="metric-row"><span class="metric-label">Lifetime</span><span class="metric-value">${lifetime}</span></div>
                            <div class="metric-row"><span class="metric-label">Plan</span><span class="metric-value">${plan}</span></div>
                        </article>
                    `;
                });

                html += `
                        </div>
                    </section>
                `;
            });

            html += '</div>';
            container.innerHTML = html;
        }


        function renderChart(performance) {
            const ctx = document.getElementById('yieldChart').getContext('2d');
            
            if (yieldChart) {
                yieldChart.destroy();
            }

            yieldChart = new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: ['🟢 Active', '🔵 Planning', '🟠 Review'],
                    datasets: [{
                        data: [
                            performance.percentages.active,
                            performance.percentages.planning,
                            performance.percentages.review
                        ],
                        backgroundColor: [
                            '#4CAF50',
                            '#2196F3',
                            '#FF9800'
                        ],
                        borderColor: '#fff',
                        borderWidth: 3,
                        hoverOffset: 10
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                padding: 15,
                                font: {
                                    size: 12,
                                    weight: '500'
                                }
                            }
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return context.label + ': ' + context.parsed + '%';
                                }
                            }
                        }
                    }
                }
            });
        }

        function updateInfoBox(performance) {
            document.getElementById('totalQty').textContent = 
                performance.total_quantity.toLocaleString();
            document.getElementById('prodRate').textContent = 
                performance.percentages.active.toFixed(1) + '%';
            document.getElementById('planRate').textContent = 
                performance.percentages.planning.toFixed(1) + '%';
            document.getElementById('reviewRate').textContent = 
                performance.percentages.review.toFixed(1) + '%';
            document.getElementById('yieldRate').textContent = 
                (performance.percentages.active + performance.percentages.review).toFixed(1) + '%';
        }

        function updateTimestamp(timestamp) {
            document.getElementById('timestamp').textContent = '🕐 ' + timestamp;
        }

        function showError(message) {
            document.getElementById('errorMessage').innerHTML = 
                `<div class="error-message">${message}</div>`;
        }

        function clearError() {
            document.getElementById('errorMessage').innerHTML = '';
        }

        document.addEventListener('DOMContentLoaded', loadData);
        setInterval(loadData, 30000);
    </script>
